# Podcast Index API — get keys at https://api.podcastindex.org/
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# Spark rail uses @buildonspark/spark-sdk — no API key required (the SDK
# talks directly to Spark's signing operators). Self-custodial; seed lives
# NIP-44-encrypted on the user's Nostr relays.

# Optional: app identity for Podcast Index User-Agent
APP_NAME=boostmebitch

# BoostBox metadata service (https://github.com/ChadFarrow/boostbox)
# Used on the LNURL leg of boosts to ship the boostagram out-of-band via the
# LUD-21 comment field. The default URL points at tardbox.com; the API key
# below is the public reference key — replace it with the key for whatever
# BoostBox instance you're hitting (tardbox.com runs its own).
BOOSTBOX_URL=https://tardbox.com
BOOSTBOX_API_KEY=v4v4me

# Libre Listener Wallet embed (in-page Lightning wallet, the iOS boost rail).
# Google OAuth client id of the "Libre-wallet web" client — NEXT_PUBLIC_ by
# design, a client id is not a secret. The app's origins must be registered
# on that client (Authorized JavaScript origins AND redirect URIs, bare
# origin, no trailing slash). Absent = the Libre rail is hidden entirely.
NEXT_PUBLIC_LIBRE_GOOGLE_CLIENT_ID=
